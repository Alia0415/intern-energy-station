# ============================================================
# 环境变量示例 —— 复制本文件为 .env.local 后填写（.env.local 不会被提交）
#   cp .env.example .env.local
# ============================================================

# DeepSeek API Key（仅后端 server/index.js 读取，前端不会拿到）
DEEPSEEK_API_KEY=

# 可选：自定义 DeepSeek 接口地址与模型
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_MODEL=deepseek-chat

# 可选：后端端口（改了记得同步 vite.config.js 里的 API_PORT）
PORT=8787
